{
  "name": "quantdesk-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "pack": "electron-builder --dir",
    "dist": "vite build && electron-builder",
    "mobile:build": "vite build && npx cap sync",
    "mobile:android": "npx cap open android",
    "mobile:ios": "npx cap open ios",
    "mobile:run:android": "npx cap run android",
    "mobile:run:ios": "npx cap run ios",
    "mobile:live": "vite build && npx cap sync && npx cap run android --livereload"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/cli": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@capacitor/preferences": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "axios": "^1.7.2",
    "astral-regex": "^2.0.0",
    "date-fns": "^3.6.0",
    "lightweight-charts": "^4.2.0",
    "lucide-react": "^0.395.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.23.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^43.1.0",
    "electron-builder": "^24.13.3",
    "vite": "^5.3.1"
  },
  "build": {
    "appId": "com.quantdesk.terminal",
    "productName": "QuantDesk",
    "win": {
      "target": "nsis"
    },
    "files": [
      "dist/**/*",
      "electron-main.cjs",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!node_modules/.cache/**/*",
          "!**/*.log"
        ]
      },
      {
        "from": "../py-service",
        "to": "py-service",
        "filter": [
          "**/*",
          "!.venv/**/*",
          "!venv/**/*",
          "!__pycache__/**/*"
        ]
      }
    ]
  }
}
